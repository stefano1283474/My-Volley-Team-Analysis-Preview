rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerUid) {
      return isSignedIn() && request.auth.uid == ownerUid;
    }

    function isBootstrapAdminEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'peraimodel@gmail.com';
    }

    function requesterEmail() {
      return request.auth.token.email != null ? request.auth.token.email.lower() : '';
    }

    function isAdminUser() {
      let userRef = /databases/$(database)/documents/volley_team_analysis_6_0_users/$(request.auth.uid);
      return isSignedIn()
        && (isBootstrapAdminEmail()
            || (exists(userRef) && get(userRef).data.role == 'admin'));
    }

    function isOwnUserDoc(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isShareEnabled(data) {
      return !('enabled' in data) || data.enabled == true;
    }

    function hasPublicAccess(data) {
      return (('publicAccess' in data) && data.publicAccess == true)
        || (!('publicAccess' in data) && (!('allowedEmails' in data) || data.allowedEmails.size() == 0));
    }

    function hasRestrictedAccess(data) {
      return ('allowedEmails' in data)
        && request.auth.token.email != null
        && request.auth.token.email.lower() in data.allowedEmails;
    }

    function hasWriterAccess(data) {
      return ('writerEmails' in data)
        && request.auth.token.email != null
        && request.auth.token.email.lower() in data.writerEmails;
    }

    function isAllowedReader(ownerUid) {
      let sharedRef = /databases/$(database)/documents/volley_team_analysis_6_0_shared_access/$(ownerUid);
      let d = get(sharedRef).data;
      return isSignedIn()
        && exists(sharedRef)
        && isShareEnabled(d)
        && (hasPublicAccess(d) || hasRestrictedAccess(d));
    }

    function isAllowedWriter(ownerUid) {
      let sharedRef = /databases/$(database)/documents/volley_team_analysis_6_0_shared_access/$(ownerUid);
      let d = get(sharedRef).data;
      return isSignedIn()
        && exists(sharedRef)
        && isShareEnabled(d)
        && hasWriterAccess(d);
    }

    // Dataset matches e calendario
    match /volley_team_analysis_6_0/{ownerUid}/datasets/{docId} {
      allow read: if isOwner(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete: if isOwner(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Bacheca team news per dataset owner
    match /volley_team_analysis_6_0_news/{ownerUid} {
      allow read: if isOwner(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete: if isOwner(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Documento shared_access (configurazione condivisione dell'owner)
    // Usa resource.data direttamente per evitare get() ricorsivo sullo stesso doc
    match /volley_team_analysis_6_0_shared_access/{ownerUid} {
      allow read: if isOwner(ownerUid)
        || (isSignedIn()
            && isShareEnabled(resource.data)
            && (hasPublicAccess(resource.data) || hasRestrictedAccess(resource.data)));
      allow create, update, delete: if isOwner(ownerUid);
    }

    // Token di condivisione (letti per validare il link)
    match /volley_team_analysis_6_0_share_tokens/{token} {
      allow read: if isSignedIn()
        && isShareEnabled(resource.data)
        && (resource.data.ownerUid == request.auth.uid
            || isAllowedReader(resource.data.ownerUid));
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /volley_team_analysis_6_0_users/{uid} {
      allow get: if isOwnUserDoc(uid) || isAdminUser();
      allow list: if isAdminUser();
      allow create: if isOwnUserDoc(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == requesterEmail()
        && request.resource.data.assignedProfile in ['base', 'pro', 'promax']
        && request.resource.data.role == (isBootstrapAdminEmail() ? 'admin' : 'user');
      allow update: if isAdminUser()
        || (isOwnUserDoc(uid)
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.email == resource.data.email
            && request.resource.data.role == resource.data.role
            && request.resource.data.assignedProfile == resource.data.assignedProfile);
      allow delete: if isAdminUser();
    }
  }
}
