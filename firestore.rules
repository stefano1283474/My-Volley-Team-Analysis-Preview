rules_version = '2';
// ============================================================================
// FIRESTORE SECURITY RULES — Unified (My Volley Scout + My Volley Team Analysis)
// Progetto Firebase: volley-data-studio
//
// Strutture dati gestite:
//   [MVS]  users/{email}/teams/{teamId}/matches/{matchId}
//   [MVS]  users/{email}/... (tutte le subcollection MVS)
//   [MVTA] users/{uid}/shared_access/config        (NEW)
//   [MVTA] users/{uid}/news/posts                   (NEW)
//   [MVTA] users/{uid}/offers/list                  (NEW)
//   [MVTA] users/{uid}/usage/log                    (NEW)
//   [MVTA] users/_global_tokens/share_tokens/{tok}  (NEW)
//   [MVTA] users/_admin/content/{docId}             (NEW)
//   [MVTA legacy] volley_team_analysis_6_0/{uid}/datasets/{docId}
//   [MVTA legacy] volley_team_analysis_6_0_users/{uid}
//   [MVTA legacy] volley_team_analysis_6_0_shared_access/{ownerUid}
//   [MVTA legacy] volley_team_analysis_6_0_share_tokens/{token}
//   [MVTA legacy] volley_team_analysis_6_0_profile_requests/{uid}
//   [MVTA legacy] volley_team_analysis_6_0_user_usage/{uid}
//   [MVTA legacy] volley_team_analysis_6_0_news/{ownerUid}
//   [MVTA legacy] volley_team_analysis_6_0_offers/{ownerUid}
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funzioni helper comuni ──────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // MVTA: ownership basata su Firebase Auth UID
    function isOwner(ownerUid) {
      return isSignedIn() && request.auth.uid == ownerUid;
    }

    // MVS: ownership basata su email (il documento utente MVS è indicizzato per email)
    function isUser(userId) {
      return isSignedIn() && (
        request.auth.uid == userId ||
        (request.auth.token.email != null && request.auth.token.email.lower() == userId) ||
        (request.auth.token.email != null && request.auth.token.email.lower().replace('.', '_') == userId)
      );
    }

    function isBootstrapAdminEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'peraimodel@gmail.com';
    }

    function requesterEmail() {
      return request.auth.token.email != null ? request.auth.token.email.lower() : '';
    }

    function isAdminUser() {
      let legacyUserRef = /databases/$(database)/documents/volley_team_analysis_6_0_users/$(request.auth.uid);
      let unifiedUserRef = /databases/$(database)/documents/users/$(requesterEmail());
      return isSignedIn()
        && (isBootstrapAdminEmail()
            || (exists(unifiedUserRef) && get(unifiedUserRef).data.role == 'admin')
            || (exists(legacyUserRef) && get(legacyUserRef).data.role == 'admin'));
    }

    function isOwnUserDoc(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Funzioni di condivisione MVTA ───────────────────────────────────────

    function isShareEnabled(data) {
      return !('enabled' in data) || data.enabled == true;
    }

    function hasPublicAccess(data) {
      return (('publicAccess' in data) && data.publicAccess == true)
        || (!('publicAccess' in data) && (!('allowedEmails' in data) || data.allowedEmails.size() == 0));
    }

    function hasRestrictedAccess(data) {
      return ('allowedEmails' in data)
        && request.auth.token.email != null
        && request.auth.token.email.lower() in data.allowedEmails;
    }

    function hasWriterAccess(data) {
      return ('writerEmails' in data)
        && request.auth.token.email != null
        && request.auth.token.email.lower() in data.writerEmails;
    }

    function isAllowedReader(ownerUid) {
      let sharedRef = /databases/$(database)/documents/volley_team_analysis_6_0_shared_access/$(ownerUid);
      let d = get(sharedRef).data;
      return isSignedIn()
        && exists(sharedRef)
        && isShareEnabled(d)
        && (hasPublicAccess(d) || hasRestrictedAccess(d));
    }

    function isAllowedWriter(ownerUid) {
      let sharedRef = /databases/$(database)/documents/volley_team_analysis_6_0_shared_access/$(ownerUid);
      let d = get(sharedRef).data;
      return isSignedIn()
        && exists(sharedRef)
        && isShareEnabled(d)
        && hasWriterAccess(d);
    }

    // ── Funzioni di accesso MVS (team sharing) ──────────────────────────────

    function hasTeamAccess(ownerId, teamId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(ownerId)/teams/$(teamId)/user_access/$(request.auth.token.email)) ||
        exists(/databases/$(database)/documents/users/$(ownerId)/teams/$(teamId)/user_access/$(request.auth.token.email.replace('.', '_')))
      );
    }

    function hasSharedMirror(ownerId, teamId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.token.email)/shared_teams/$(ownerId + '__' + teamId)) ||
        exists(/databases/$(database)/documents/users/$(request.auth.token.email.replace('.', '_'))/shared_teams/$(ownerId + '__' + teamId))
      );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // REGOLE MY VOLLEY SCOUT (MVS)
    // Struttura: users/{email}/teams/{teamId}/matches/{matchId}
    // Identificazione utente: email (non UID)
    // ══════════════════════════════════════════════════════════════════════════

    // Documento utente MVS
    match /users/{userId} {
      allow get: if isUser(userId) || isAdminUser();
      allow list: if isAdminUser();
      allow create, update: if isUser(userId);
      allow delete: if isUser(userId) || isAdminUser();
    }

    // Tutte le subcollection MVS sotto /users/{userId}/
    match /users/{userId}/{document=**} {
      allow read, write: if isUser(userId);
    }

    // Accesso ai team (con condivisione)
    match /users/{ownerId}/teams/{teamId} {
      allow read: if isUser(ownerId) || hasTeamAccess(ownerId, teamId) || hasSharedMirror(ownerId, teamId);
      allow write: if isUser(ownerId);
    }

    match /users/{ownerId}/teams/{teamId}/{document=**} {
      allow read: if isUser(ownerId) || hasTeamAccess(ownerId, teamId) || hasSharedMirror(ownerId, teamId);
      allow write: if isUser(ownerId);
    }

    match /users/{ownerId}/teams/{teamId}/user_access/{userId} {
      allow read: if isUser(ownerId) || isUser(userId) || hasTeamAccess(ownerId, teamId);
      allow create, update: if isUser(ownerId) || isUser(userId);
      allow delete: if isUser(ownerId);
    }

    match /users/{ownerId}/invites/{inviteId} {
      allow read: if isSignedIn();
      allow write: if isUser(ownerId);
    }

    match /teamInvites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.token.email;
    }

    // Regole legacy (vecchie collection flat MVS)
    match /matches/{matchId} {
      allow read, write: if request.auth != null &&
                          (resource.data.userId == request.auth.token.email ||
                           resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           resource.data.userId == request.auth.uid ||
                           request.resource.data.userId == request.auth.token.email ||
                           request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           request.resource.data.userId == request.auth.uid);
    }

    match /rosters/{rosterId} {
      allow read, write: if request.auth != null &&
                          (resource.data.userId == request.auth.token.email ||
                           resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           resource.data.userId == request.auth.uid ||
                           request.resource.data.userId == request.auth.token.email ||
                           request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           request.resource.data.userId == request.auth.uid);
    }

    match /teams/{teamId} {
      allow read, write: if request.auth != null &&
                          (resource.data.userId == request.auth.token.email ||
                           resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           resource.data.userId == request.auth.uid ||
                           request.resource.data.userId == request.auth.token.email ||
                           request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           request.resource.data.userId == request.auth.uid);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // REGOLE UNIFICATE MVTA (nuove sub-collection sotto users/)
    // Questi path sostituiscono le root collection legacy. Le regole legacy
    // rimangono attive per backward compatibility durante la migrazione.
    // ══════════════════════════════════════════════════════════════════════════

    // Shared access config (nuovo path: users/{uid}/shared_access/config)
    match /users/{ownerUid}/shared_access/{docId} {
      allow read: if isUser(ownerUid)
        || (isSignedIn()
            && isShareEnabled(resource.data)
            && (hasPublicAccess(resource.data) || hasRestrictedAccess(resource.data)));
      allow create, update, delete: if isUser(ownerUid);
    }

    // News (nuovo path: users/{uid}/news/{docId})
    match /users/{ownerUid}/news/{docId} {
      allow read: if isUser(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete: if isUser(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Offers (nuovo path: users/{uid}/offers/{docId})
    match /users/{ownerUid}/offers/{docId} {
      allow read: if isUser(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete: if isUser(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Usage log (nuovo path: users/{uid}/usage/{docId})
    match /users/{ownerUid}/usage/{docId} {
      allow get: if isUser(ownerUid) || isAdminUser();
      allow list: if isAdminUser();
      allow create, update: if isUser(ownerUid);
      allow delete: if isAdminUser();
    }

    // Global share tokens (nuovo path: users/_global_tokens/share_tokens/{token})
    match /users/_global_tokens/share_tokens/{token} {
      allow read: if isSignedIn()
        && isShareEnabled(resource.data)
        && (resource.data.ownerUid == request.auth.uid
            || isAllowedReader(resource.data.ownerUid));
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Admin content (nuovo path: users/_admin/content/{docId})
    match /users/_admin/content/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdminUser();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // REGOLE MY VOLLEY TEAM ANALYSIS (MVTA) — LEGACY
    // Struttura: volley_team_analysis_6_0/{uid}/datasets/{docId}
    // Identificazione utente: Firebase Auth UID
    // Queste regole restano attive per backward compatibility.
    // ══════════════════════════════════════════════════════════════════════════

    // Dataset match e calendario
    // Sia MVS (tramite saveMVTAMatch) che MVTA possono scrivere con il proprio UID
    match /volley_team_analysis_6_0/{ownerUid}/datasets/{docId} {
      allow read: if isOwner(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete: if isOwner(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Bacheca team news (notifiche personali per-utente)
    match /volley_team_analysis_6_0_news/{ownerUid} {
      allow read: if isOwner(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete: if isOwner(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Offerte team (legacy per-user — mantenuto per backward compat)
    match /volley_team_analysis_6_0_offers/{ownerUid} {
      allow read: if isOwner(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete: if isOwner(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Admin Content globale (Sistema posts + Offerte con visibilità per profilo/utente)
    // Lettura: qualsiasi utente autenticato (il filtro visibilità è applicato lato client)
    // Scrittura: solo admin (ruolo verificato su volley_team_analysis_6_0_users)
    match /volley_team_analysis_6_0_admin_content/{docId} {
      allow read:                   if isSignedIn();
      allow create, update, delete: if isAdminUser();
    }

    // Telemetria utilizzo utente
    match /volley_team_analysis_6_0_user_usage/{uid} {
      allow get: if isOwnUserDoc(uid) || isAdminUser();
      allow list: if isAdminUser();
      allow create, update: if isOwnUserDoc(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == requesterEmail();
      allow delete: if isAdminUser();
    }

    // Richieste upgrade profilo
    match /volley_team_analysis_6_0_profile_requests/{uid} {
      allow get: if isOwnUserDoc(uid) || isAdminUser();
      allow list: if isAdminUser();
      allow create: if isOwnUserDoc(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == requesterEmail()
        && request.resource.data.currentProfile in ['base', 'pro', 'promax']
        && request.resource.data.targetProfile in ['pro', 'promax']
        && request.resource.data.status == 'pending';
      allow update: if isAdminUser()
        || (isOwnUserDoc(uid)
            && resource.data.status == 'pending'
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.email == resource.data.email
            && request.resource.data.currentProfile in ['base', 'pro', 'promax']
            && request.resource.data.targetProfile in ['pro', 'promax']
            && request.resource.data.status == 'pending');
      allow delete: if isAdminUser();
    }

    // Shared access (configurazione condivisione dell'owner MVTA)
    match /volley_team_analysis_6_0_shared_access/{ownerUid} {
      allow read: if isOwner(ownerUid)
        || (isSignedIn()
            && isShareEnabled(resource.data)
            && (hasPublicAccess(resource.data) || hasRestrictedAccess(resource.data)));
      allow create, update, delete: if isOwner(ownerUid);
    }

    // Token di condivisione MVTA
    match /volley_team_analysis_6_0_share_tokens/{token} {
      allow read: if isSignedIn()
        && isShareEnabled(resource.data)
        && (resource.data.ownerUid == request.auth.uid
            || isAllowedReader(resource.data.ownerUid));
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Registro utenti MVTA
    match /volley_team_analysis_6_0_users/{uid} {
      allow get: if isOwnUserDoc(uid) || isAdminUser();
      allow list: if isAdminUser();
      allow create: if isOwnUserDoc(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == requesterEmail()
        && (
            (isBootstrapAdminEmail()
              && request.resource.data.role == 'admin'
              && request.resource.data.assignedProfile in ['base', 'pro', 'promax'])
            ||
            (!isBootstrapAdminEmail()
              && request.resource.data.role == 'user'
              && request.resource.data.assignedProfile == 'base')
           );
      allow update: if isAdminUser()
        || (isOwnUserDoc(uid)
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.email == resource.data.email
            && request.resource.data.role == resource.data.role
            && request.resource.data.assignedProfile == resource.data.assignedProfile);
      allow delete: if isAdminUser();
    }

  }
}
